# ══════════════════════════════════════════════════════════════
# Intelligent Cognitive Alarm Platform — Environment Variables
# ══════════════════════════════════════════════════════════════

# ── General ──────────────────────────────────────────────────
APP_NAME=Intelligent Cognitive Alarm Platform
ENVIRONMENT=local
DEBUG=true

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=icap
POSTGRES_PASSWORD=icap_dev_password
POSTGRES_DB=icap
DATABASE_URL=postgresql+asyncpg://icap:icap_dev_password@db:5432/icap

# ── MongoDB ──────────────────────────────────────────────────
MONGO_URL=mongodb://icap:icap_dev_password@mongo:27017
MONGO_DB_NAME=icap_analytics

# ── JWT Authentication ───────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Firebase Cloud Messaging ────────────────────────────────
FIREBASE_CREDENTIALS_PATH=

# ── CORS ─────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
